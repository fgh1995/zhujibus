<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- 位置：Android 12+ 需同时申请 FINE 和 COARSE -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- 相机/麦克风：视频录制必备，Android 6.0+ 需运行时申请 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- 存储权限：分级适配 Android 7-15 -->
    <!-- Android 13+ (API33+)：读视频用 READ_MEDIA_VIDEO；写入 MediaStore 不需要权限 -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- Android 12 及以下 (API<=32)：读相册用 READ_EXTERNAL_STORAGE -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Android 9 及以下 (API<=28)：写外部存储用 WRITE_EXTERNAL_STORAGE -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Android 13+ (API33+)：通知权限独立申请 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 前台服务：录制后台运行 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+：前台服务按场景拆分 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- 高德地图/定位 SDK -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <!-- 高德 SDK 9.3.0 内部会向 Settings.System 写入状态/隐私协议标记，必须声明此权限 -->
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />
    <!-- MIUI 蓝牙定位（MiuiBlueLocationManager#noteOpUseMyIdentity）需要声明，否则日志会刷屏警告 -->
    <uses-permission android:name="miui.permission.USE_MY_IDENTITY" />

    <queries>
        <!-- 查询已安装的TTS引擎 -->
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/zhuji_bus_logo_round"
        android:label="@string/app_name"
        android:roundIcon="@drawable/zhuji_bus_logo_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.诸暨公交"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        <!-- 高德地图 API Key（需要替换为你自己的高德 Key） -->
        <meta-data
            android:name="com.amap.api.v2.apikey"
            android:value="288dfa7bca2d4a51c94b4420fee4f633" />
        <!-- 高德定位服务（必须声明，否则定位 SDK 无法使用） -->
        <service
            android:name="com.amap.api.location.APSService"
            android:exported="false" />
        <activity
            android:name=".CameraActivity"
            android:exported="false"
            android:theme="@style/Theme.诸暨公交"
            android:screenOrientation="landscape" />
        <activity
            android:name=".NoticeDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.诸暨公交" />
        <activity
            android:name=".NoticeListActivity"
            android:exported="false"
            android:theme="@style/Theme.诸暨公交" />
        <activity
            android:name=".BusLineDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.诸暨公交" />
        <activity
            android:name=".BusRouteSearchActivity"
            android:exported="false"
            android:theme="@style/Theme.诸暨公交" />
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>