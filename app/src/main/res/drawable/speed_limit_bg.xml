<!-- res/drawable/speed_limit_bg.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <!-- 白色填充底色 -->
    <solid android:color="#FFFFFF" />
    <!-- 红色环形边框 -->
    <stroke
        android:width="4dp"
        android:color="#FF0000" />
    <!-- 确保是标准圆形，需在布局中设置宽高相等 -->
    <size
        android:width="60dp"
        android:height="60dp" />
</shape>
