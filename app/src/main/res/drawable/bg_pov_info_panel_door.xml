<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- 黄色背景 -->
    <solid android:color="#FFD600" />
    <!-- 黑色边框 -->
    <stroke
        android:width="1dp"
        android:color="#000000" />
    <!-- 整体圆角 -->
    <corners android:radius="4dp" />
    <!-- 内边距，留出顶部白色区域空间 -->
    <padding
        android:top="5dp"
        android:left="4dp"
        android:right="4dp"
        android:bottom="2dp" />
</shape>