<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 半透明黑色背景，与原背景一致 -->
    <solid android:color="#44000000" />
    <!-- 可选白色边框，宽度 2dp，如果你不想要边框可以删除这一行 -->
    <stroke
        android:width="4dp"
        android:color="#FF9800" />
    <!-- 圆角半径，12dp，可自行调整 -->
    <corners android:radius="6dp" />
</shape>