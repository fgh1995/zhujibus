<?xml version="1.0" encoding="utf-8"?>
<!--
  主页 fragment：地图显示区 + 下方线路信息面板 + 右侧信息栏
  由 BusLineDetailActivity 通过 FragmentContainerView 承载
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal">

    <!-- ========== 中间地图区 + 线路信息 ========== -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- 地图显示区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/nav_map_panel_bg"
            android:padding="1dp">

            <com.amap.api.maps.TextureMapView
                android:id="@+id/amap_map_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/nav_map_inside_bg"
                android:clipToOutline="true" />
        </LinearLayout>

        <!-- 下方线路信息面板 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/nav_panel_bg"
            android:padding="5dp"
            android:layout_marginTop="6dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:gravity="center_vertical">
                <org.zjfgh.zhujibus.HorizontalScrollTextView
                    android:id="@+id/nav_direction"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    app:hsText="加载中..."
                    app:hsAnimationMode="bounce_with_pause"
                    app:hsTurnPauseDuration="1500"
                    app:hsScrollSpeed="60"
                    app:hsTextSize="14sp"
                    app:hsCharPerSecond="1.5"
                    app:hsTextColor="#FFFFFF"
                    app:hsGravity="left" />
                <TextView
                    android:id="@+id/nav_swap_orientation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="换向"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:background="@drawable/nav_tab_active_bg" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="5dp">
                <TextView
                    android:id="@+id/first_bus_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="首：--:--"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:layout_marginEnd="5dp"/>

                <TextView
                    android:id="@+id/last_bus_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="末：--:--"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp" />
                <TextView
                    android:id="@+id/ticket"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAlignment="textEnd"
                    android:text="票价：--.--"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp" />
            </LinearLayout>
            <!-- 线路图 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="horizontal">
                <org.zjfgh.zhujibus.IBusCloudLineView
                    android:id="@+id/i_bus_cloud_line_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ========== 右侧信息栏 ========== -->
    <LinearLayout
        android:layout_width="110dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginStart="6dp">

        <!-- 时间 + 日期面板 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="5dp"
            android:background="@drawable/nav_panel_bg">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/nav_time_hm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="09:19"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="2dp"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/nav_time_second"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:text="23"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <TextView
                android:id="@+id/nav_date_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="8月21日 周三"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 线路信息 + 限速速度（同一卡片，中间分割线） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/nav_panel_bg"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginTop="6dp">

            <!-- 上部：线路信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="5dp"
                android:gravity="center_horizontal">

                <org.zjfgh.zhujibus.HorizontalScrollTextView
                    android:id="@+id/nav_route_no"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:hsText="---"
                    app:hsTextSize="15sp"
                    app:hsAnimationMode="bounce_with_pause"
                    app:hsTurnPauseDuration="1500"
                    app:hsScrollSpeed="60"
                    app:hsCharPerSecond="1.5"
                    app:hsTextColor="#FFFFFF"
                    app:hsGravity="center"/>
                <TextView
                    android:id="@+id/route_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="总里程：-11公里"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <org.zjfgh.zhujibus.HorizontalScrollTextView
                        android:id="@+id/nav_next_station"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:hsTextSize="9sp"
                        app:hsText="--------"
                        app:hsAnimationMode="bounce_with_pause"
                        app:hsTurnPauseDuration="1500"
                        app:hsScrollSpeed="60"
                        app:hsCharPerSecond="1.5"
                        app:hsTextColor="#FFFFFF"
                        app:hsGravity="center"/>
                </LinearLayout>

            </LinearLayout>

            <!-- 中间分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:background="#252A45" />

            <!-- 下部：限速圆标 + 实时速度 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="bottom">

                <!-- 限速圆标 -->
                <FrameLayout
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:layout_gravity="center_horizontal">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/speed_limit_bg" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="55"
                        android:textColor="#000000"
                        android:textSize="35sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- 实时速度（大号数字） -->
                <TextView
                    android:id="@+id/gps_speed_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:gravity="bottom"
                    android:text="0"
                    android:textColor="#37D4F4"
                    android:textSize="60sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
