<?xml version="1.0" encoding="utf-8"?>
<!--
  主页 fragment：地图显示区 + 下方线路信息面板 + 右侧信息栏
  由 BusLineDetailActivity 通过 FragmentContainerView 承载
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- ========== 中间地图区 + 线路信息 ========== -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- 地图显示区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/nav_map_panel_bg"
            android:padding="1dp">

            <com.amap.api.maps.TextureMapView
                android:id="@+id/amap_map_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/nav_map_inside_bg"
                android:clipToOutline="true" />
        </LinearLayout>

        <!-- 下方线路信息面板 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/nav_panel_bg"
            android:padding="10dp"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/nav_direction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加载中..."
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <!-- 线路图占位 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:orientation="horizontal">
                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="#5A6090" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ========== 右侧信息栏 ========== -->
    <LinearLayout
        android:layout_width="100dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginStart="6dp">

        <!-- 时间 + 日期面板 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/nav_panel_bg">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/nav_time_hm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="09:19"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="2dp"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/nav_time_second"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:text="23"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <TextView
                android:id="@+id/nav_date_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="8月21日 周三"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 线路信息 + 限速速度（同一卡片，中间分割线） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/nav_panel_bg"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginTop="6dp">

            <!-- 上部：线路信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/nav_route_no"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="237路"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/nav_next_station"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:layout_marginTop="4dp"
                    android:text="下一站: 东方路五一路"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp" />
            </LinearLayout>

            <!-- 中间分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:background="#252A45" />

            <!-- 下部：限速圆标 + 实时速度 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <!-- 限速圆标 -->
                <FrameLayout
                    android:layout_width="66dp"
                    android:layout_height="66dp"
                    android:layout_gravity="center_horizontal">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/speed_limit_bg" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="55"
                        android:textColor="#000000"
                        android:textSize="42sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- 实时速度（大号数字） -->
                <TextView
                    android:id="@+id/gps_speed_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:gravity="bottom"
                    android:text="0"
                    android:textColor="#37D4F4"
                    android:textSize="60sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
