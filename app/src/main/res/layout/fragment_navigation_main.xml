<?xml version="1.0" encoding="utf-8"?>
<!--
  主页 fragment：地图显示区 + 下方线路信息面板 + 右侧信息栏
  由 BusLineDetailActivity 通过 FragmentContainerView 承载
  优化：地图与线路信息面板按比例分配，线路图高度自适应填充
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <!-- ========== 中间地图区 + 线路信息（占剩余全部宽度） ========== -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- 地图显示区：占据约 60% 的高度 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="55"
            android:background="@drawable/nav_map_panel_bg"
            android:padding="1dp">

            <com.amap.api.maps.TextureMapView
                android:id="@+id/amap_map_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/nav_map_inside_bg"
                android:clipToOutline="true" />
        </LinearLayout>

        <!-- 下方线路信息面板：占据约 40% 的高度 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="45"
            android:layout_marginTop="6dp"
            android:background="@drawable/nav_panel_bg"
            android:orientation="vertical"
            android:padding="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:gravity="center_vertical">

                <org.zjfgh.zhujibus.HorizontalScrollTextView
                    android:id="@+id/nav_direction"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    app:hsAnimationMode="bounce_with_pause"
                    app:hsCharPerSecond="1.5"
                    app:hsGravity="left"
                    app:hsScrollSpeed="60"
                    app:hsText="加载中..."
                    app:hsTextColor="#FFFFFF"
                    app:hsTextSize="14sp"
                    app:hsTurnPauseDuration="1500" />

                <TextView
                    android:id="@+id/nav_swap_orientation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/nav_tab_active_bg"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:text="换向"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/first_bus_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:text="首：--:--"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/last_bus_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="末：--:--"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/ticket"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="票价：--.--"
                    android:textAlignment="textEnd"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- 线路图：高度自动填充剩余空间 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <org.zjfgh.zhujibus.IBusCloudLineView
                    android:id="@+id/i_bus_cloud_line_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ========== 右侧信息栏：外层约束布局，时间卡片、速度卡片同层级可互相引用id ========== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_marginStart="6dp">

        <!-- 时间 + 日期面板 -->
        <LinearLayout
            android:id="@+id/layout_time_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/nav_panel_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/nav_time_hm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="2dp"
                    android:includeFontPadding="false"
                    android:text="09:19"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/nav_time_second"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minEms="1"
                    android:includeFontPadding="false"
                    android:text="23"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/nav_date_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="8月21日 周三"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 线路信息 + 限速速度卡片（内部约束布局，最小宽度等于上方时间卡片） -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_speed_card"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/nav_panel_bg"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_time_card"
            app:layout_constraintWidth_min="@id/layout_time_card">

            <!-- 上部：线路信息 -->
            <LinearLayout
                android:id="@+id/layout_route_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="5dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <org.zjfgh.zhujibus.HorizontalScrollTextView
                    android:id="@+id/nav_route_no"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:hsAnimationMode="bounce_with_pause"
                    app:hsCharPerSecond="1.5"
                    app:hsGravity="center"
                    app:hsScrollSpeed="60"
                    app:hsText="---"
                    app:hsTextColor="#FFFFFF"
                    app:hsTextSize="15sp"
                    app:hsTurnPauseDuration="1500" />

                <TextView
                    android:id="@+id/route_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="总里程：--公里"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <org.zjfgh.zhujibus.HorizontalScrollTextView
                        android:id="@+id/nav_next_station"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:hsAnimationMode="bounce_with_pause"
                        app:hsCharPerSecond="1.5"
                        app:hsGravity="center"
                        app:hsScrollSpeed="60"
                        app:hsText="--------"
                        app:hsTextColor="#FFFFFF"
                        app:hsTextSize="9sp"
                        app:hsTurnPauseDuration="1500" />
                </LinearLayout>
            </LinearLayout>

            <!-- 中间分割线 -->
            <View
                android:id="@+id/view_divider"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginStart="2dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="2dp"
                android:layout_marginBottom="6dp"
                android:background="#252A45"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layout_route_info" />

            <!-- 下部：限速圆标 + 实时速度 -->
            <LinearLayout
                android:id="@+id/layout_speed_area"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="bottom"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/view_divider">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal">

                    <FrameLayout
                        android:id="@+id/speedCircle"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:background="@drawable/speed_limit_bg"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintDimensionRatio="1:1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="5dp"
                        android:text="55"
                        android:textColor="#000000"
                        android:textSize="45sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/speedCircle"
                        app:layout_constraintEnd_toEndOf="@id/speedCircle"
                        app:layout_constraintStart_toStartOf="@id/speedCircle"
                        app:layout_constraintTop_toTopOf="@id/speedCircle" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- 实时速度（大号数字区域） -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center">
                    <ImageView
                        android:id="@+id/icon_gps_signal"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="5dp"
                        android:src="@drawable/icon_gps_not_signal" />

                    <TextView
                        android:id="@+id/gps_speed_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp"
                        android:minEms="1"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="--"
                        android:textAlignment="center"
                        android:textColor="#37D4F4"
                        android:textSize="50sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/icon_network_signal"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_gravity="bottom"
                        android:layout_marginEnd="5dp"
                        android:src="@drawable/icon_network_0" />
                </LinearLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>