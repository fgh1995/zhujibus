<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- 站点序号圆圈 -->
    <TextView
        android:id="@+id/station_order"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@drawable/blue_circle"
        android:gravity="center"
        android:text="1"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 站点名称 -->
    <TextView
        android:id="@+id/station_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#333333"
        android:textSize="16sp"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/station_order"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/station_order"
        app:layout_constraintBottom_toBottomOf="@id/station_order" />

    <!-- 连接线 -->
    <View
        android:id="@+id/line_bottom"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#0070FD"
        app:layout_constraintStart_toStartOf="@id/station_order"
        app:layout_constraintTop_toBottomOf="@id/station_order"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- 到站车辆图标 -->
    <ImageView
        android:id="@+id/bus_status_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/bus_icon"
        android:visibility="invisible"
        app:layout_constraintStart_toStartOf="@id/station_order"
        app:layout_constraintEnd_toEndOf="@id/station_order"
        app:layout_constraintBottom_toTopOf="@id/station_order" />

    <!-- 途中车辆图标 -->
    <ImageView
        android:id="@+id/bus_on_way_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/bus_icon"
        android:visibility="invisible"
        app:layout_constraintStart_toStartOf="@id/line_bottom"
        app:layout_constraintEnd_toEndOf="@id/line_bottom"
        app:layout_constraintTop_toTopOf="@id/line_bottom"
        app:layout_constraintBottom_toBottomOf="@id/line_bottom" />

    <!-- 车牌号 -->
    <TextView
        android:id="@+id/tv_plate_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#666666"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:background="@drawable/plate_bg"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/bus_on_way_icon"
        app:layout_constraintStart_toStartOf="@id/bus_on_way_icon"
        app:layout_constraintEnd_toEndOf="@id/bus_on_way_icon" />

</androidx.constraintlayout.widget.ConstraintLayout>
