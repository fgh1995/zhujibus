<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="DotMatrixView">
        <attr name="dotMatrixPattern" format="enum">
            <enum name="accessibility" value="0" />
            <enum name="right_arrow" value="1" />
            <enum name="gps" value="2" />
            <enum name="up_down_arrow" value="3" />
        </attr>
        <attr name="dotMatrixColor" format="color" />
        <attr name="dotMatrixDotSize" format="dimension" />
    </declare-styleable>
    <declare-styleable name="HorizontalScrollTextView">
        <!-- 原有属性 -->
        <attr name="hsText" format="string" />
        <attr name="hsTextColor" format="color" />
        <attr name="hsTextSize" format="dimension" />
        <attr name="hsScrollSpeed" format="float" />
        <attr name="hsAutoStart" format="boolean" />
        <attr name="hsGravity" format="enum">
            <enum name="left" value="0" />
            <enum name="center" value="1" />
            <enum name="right" value="2" />
        </attr>
        <attr name="hsTextGap" format="dimension" />

        <!-- 新增属性 -->
        <attr name="hsAnimationMode" format="enum">
            <enum name="infinite" value="0" />
            <enum name="bounce_with_pause" value="1" />
        </attr>
        <attr name="hsTurnPauseDuration" format="integer" />
        <attr name="hsCharPerSecond" format="float" />
    </declare-styleable>
    <declare-styleable name="BorderLabel">
        <attr name="labelText" format="string" />
        <attr name="labelLitColor" format="color" />
        <attr name="labelDimColor" format="color" />
        <attr name="labelTextSize" format="dimension" />
    </declare-styleable>
    <declare-styleable name="SegmentedProgressBar">
        <!-- 背景颜色 (浅色部分) -->
        <attr name="lightColor" format="color" />
        <!-- 进度颜色 (深色部分) -->
        <attr name="darkColor" format="color" />
        <!-- 进度值 (0.0 ~ 1.0) -->
        <attr name="progress" format="float" />
        <!-- 圆角半径 -->
        <attr name="radius" format="dimension" />
    </declare-styleable>
    <declare-styleable name="VerticalScrollTextView">
        <attr name="vsText" format="string" />
        <attr name="vsTextColor" format="color" />
        <attr name="vsTextSize" format="dimension" />
        <attr name="vsScrollSpeed" format="float" />
        <attr name="vsAutoStart" format="boolean" />
        <attr name="vsGravity">
            <enum name="top" value="0" />
            <enum name="center" value="1" />
            <enum name="bottom" value="2" />
        </attr>
        <attr name="vsTextGap" format="dimension" />
        <attr name="vsAnimationMode">
            <enum name="infinite" value="0" />
            <enum name="bounce" value="1" />
        </attr>
        <attr name="vsTurnPauseDuration" format="integer" />
    </declare-styleable>
    <declare-styleable name="DotMatrixLinearLayout">
        <attr name="dmlDotRadius" format="dimension" />
        <attr name="dmlDotSpacing" format="dimension" />
        <attr name="dmlDotColor" format="color" />
        <attr name="dmlBgColor" format="color" />
        <attr name="dmlOffsetX" format="dimension" />
        <attr name="dmlOffsetY" format="dimension" />
    </declare-styleable>
</resources>
